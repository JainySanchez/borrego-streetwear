{%- liquid
  assign borrego_menu = section.settings.menu
  assign transparent_home = false
  if request.page_type == 'index' and section.settings.enable_transparent_home
    assign transparent_home = true
  endif
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --borrego-header-bg: {{ section.settings.header_background }};
    --borrego-header-text: {{ section.settings.header_text_color }};
    --borrego-header-hover: {{ section.settings.header_hover_color }};
    --borrego-header-scrolled-bg: {{ section.settings.header_scrolled_background }};
    --borrego-mega-bg: {{ section.settings.mega_menu_background }};
    --borrego-mega-text: {{ section.settings.mega_menu_text_color }};
    --borrego-logo-desktop-width: {{ section.settings.logo_width_desktop }}px;
    --borrego-logo-mobile-width: {{ section.settings.logo_width_mobile }}px;
    position: relative;
    z-index: 40;
  }

  body.borrego-header-lock {
    overflow: hidden;
  }

  .borrego-header {
    color: var(--borrego-header-text);
  }

  .borrego-header__announcement {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 3.4rem;
    padding: 0.8rem 2rem;
    background: {{ section.settings.announcement_background }};
    color: {{ section.settings.announcement_text_color }};
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    line-height: 1.3;
    text-align: center;
    text-transform: uppercase;
    text-decoration: none;
  }

  .borrego-header__shell {
    position: sticky;
    top: 0;
    z-index: 8;
    background: var(--borrego-header-bg);
    color: var(--borrego-header-text);
    transition: background 180ms ease, color 180ms ease, backdrop-filter 180ms ease, box-shadow 180ms ease;
  }

  .borrego-header.is-transparent:not(.is-scrolled) .borrego-header__shell {
    background: transparent;
    color: {{ section.settings.transparent_text_color }};
    box-shadow: none;
  }

  .borrego-header.is-scrolled .borrego-header__shell,
  .borrego-header.is-mobile-open .borrego-header__shell {
    background: {{ section.settings.header_scrolled_background | color_modify: 'alpha', 0.9 }};
    backdrop-filter: blur(14px);
    box-shadow: 0 1px 0 rgba(242, 236, 221, 0.08);
  }

  .borrego-header__bar {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    min-height: 7.8rem;
    max-width: 152rem;
    margin: 0 auto;
    padding: 0 3.2rem;
    gap: 2rem;
  }

  .borrego-header__nav-list,
  .borrego-header__utility-list,
  .borrego-header__mega-links,
  .borrego-header__mobile-list,
  .borrego-header__mobile-sublinks,
  .borrego-header__mobile-actions {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .borrego-header__desktop-nav {
    justify-self: start;
  }

  .borrego-header__nav-list {
    display: flex;
    align-items: stretch;
    gap: 2.8rem;
  }

  .borrego-header__nav-item {
    display: flex;
  }

  .borrego-header__nav-link,
  .borrego-header__icon,
  .borrego-header__mobile-toggle,
  .borrego-header__mobile-close,
  .borrego-header__mobile-link,
  .borrego-header__mobile-summary,
  .borrego-header__mobile-action,
  .borrego-header__mobile-sublink {
    color: currentColor;
    text-decoration: none;
  }

  .borrego-header__nav-link {
    display: flex;
    align-items: center;
    min-height: 7.8rem;
    border: 0;
    background: transparent;
    font: inherit;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 160ms ease;
  }

  .borrego-header__nav-link:hover,
  .borrego-header__nav-link:focus-visible,
  .borrego-header__nav-item.is-active .borrego-header__nav-link,
  .borrego-header__icon:hover,
  .borrego-header__icon:focus-visible,
  .borrego-header__mobile-action:hover,
  .borrego-header__mobile-action:focus-visible,
  .borrego-header__mobile-sublink:hover,
  .borrego-header__mobile-sublink:focus-visible {
    color: var(--borrego-header-hover);
  }

  .borrego-header__logo {
    position: relative;
    justify-self: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 9rem;
    color: currentColor;
    text-align: center;
    text-decoration: none;
  }

  .borrego-header__logo-image {
    display: block;
    width: var(--borrego-logo-desktop-width);
    max-width: 28vw;
    height: auto;
  }

  .borrego-header__logo-image--transparent,
  .borrego-header__logo-image--mobile {
    display: none;
  }

  .borrego-header.is-transparent:not(.is-scrolled) .borrego-header__logo-image--primary.has-transparent-logo {
    display: none;
  }

  .borrego-header.is-transparent:not(.is-scrolled) .borrego-header__logo-image--transparent {
    display: block;
  }

  .borrego-header__logo-text {
    font-family: var(--font-heading-family);
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .borrego-header__utilities {
    justify-self: end;
  }

  .borrego-header__utility-list {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.4rem;
  }

  .borrego-header__icon,
  .borrego-header__mobile-toggle,
  .borrego-header__mobile-close {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border: 0;
    background: transparent;
    cursor: pointer;
    transition: color 160ms ease, transform 160ms ease;
  }

  .borrego-header__icon svg,
  .borrego-header__mobile-toggle svg,
  .borrego-header__mobile-close svg,
  .borrego-header__mobile-action svg {
    width: 2rem;
    height: 2rem;
  }

  .borrego-header__cart-count {
    position: absolute;
    top: 0.4rem;
    right: 0.2rem;
    min-width: 1.7rem;
    height: 1.7rem;
    padding: 0 0.4rem;
    border-radius: 999px;
    background: var(--borrego-header-hover);
    color: #11110c;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.7rem;
    text-align: center;
  }

  .borrego-header__mega {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 7;
    pointer-events: none;
    opacity: 0;
    transform: translateY(-0.8rem);
    background: var(--borrego-mega-bg);
    color: var(--borrego-mega-text);
    border-top: 1px solid rgba(217, 178, 111, 0.18);
    box-shadow: 0 2.4rem 5rem rgba(17, 17, 12, 0.18);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .borrego-header__nav-item.is-active .borrego-header__mega,
  .borrego-header__nav-item:focus-within .borrego-header__mega {
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0);
  }

  .borrego-header__mega-inner {
    display: grid;
    grid-template-columns: minmax(24rem, 0.8fr) minmax(0, 1.2fr);
    gap: 5rem;
    max-width: 152rem;
    margin: 0 auto;
    padding: 4rem 3.2rem;
  }

  .borrego-header__mega-copy {
    display: grid;
    grid-template-columns: repeat(2, minmax(12rem, 1fr));
    gap: 3.2rem;
    align-content: start;
  }

  .borrego-header__mega-title {
    margin: 0 0 1.4rem;
    color: var(--borrego-header-hover);
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .borrego-header__mega-links {
    display: grid;
    gap: 0.7rem;
  }

  .borrego-header__mega-link {
    color: currentColor;
    font-size: 1.35rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: color 160ms ease, transform 160ms ease;
  }

  .borrego-header__mega-link:hover,
  .borrego-header__mega-link:focus-visible {
    color: var(--borrego-header-hover);
    transform: translateX(0.4rem);
  }

  .borrego-header__mega-media-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(18rem, 1fr));
    gap: 1.6rem;
  }

  .borrego-header__mega-card {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: 26rem;
    background: rgba(17, 17, 12, 0.08);
    color: #f2ecdd;
    text-decoration: none;
  }

  .borrego-header__mega-card img {
    width: 100%;
    height: 100%;
    min-height: 26rem;
    object-fit: cover;
    transition: transform 360ms ease;
  }

  .borrego-header__mega-card:hover img,
  .borrego-header__mega-card:focus-visible img {
    transform: scale(1.045);
  }

  .borrego-header__mega-caption {
    position: absolute;
    left: 1.6rem;
    right: 1.6rem;
    bottom: 1.6rem;
    z-index: 1;
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .borrego-header__mega-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 45%, rgba(17, 17, 12, 0.72));
  }

  .borrego-header__mobile-toggle,
  .borrego-header__mobile-close {
    display: none;
  }

  .borrego-header__mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 20;
    pointer-events: none;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .borrego-header.is-mobile-open .borrego-header__mobile-drawer {
    pointer-events: auto;
    opacity: 1;
  }

  .borrego-header__mobile-overlay {
    position: absolute;
    inset: 0;
    background: rgba(17, 17, 12, 0.58);
  }

  .borrego-header__mobile-panel {
    position: absolute;
    inset: 0 0 0 auto;
    display: flex;
    flex-direction: column;
    width: min(100%, 48rem);
    background: #11110c;
    color: #f2ecdd;
    transform: translateX(100%);
    transition: transform 220ms ease;
  }

  .borrego-header.is-mobile-open .borrego-header__mobile-panel {
    transform: translateX(0);
  }

  .borrego-header__mobile-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.8rem 2rem;
    border-bottom: 1px solid rgba(242, 236, 221, 0.12);
  }

  .borrego-header__mobile-brand {
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .borrego-header__mobile-content {
    overflow-y: auto;
    padding: 2.4rem 2rem 3.2rem;
  }

  .borrego-header__mobile-list {
    display: grid;
    gap: 0.4rem;
  }

  .borrego-header__mobile-link,
  .borrego-header__mobile-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1.4rem 0;
    border: 0;
    border-bottom: 1px solid rgba(242, 236, 221, 0.1);
    background: transparent;
    font: inherit;
    font-family: var(--font-heading-family);
    font-size: clamp(2.6rem, 8vw, 4.6rem);
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1;
    text-transform: uppercase;
    cursor: pointer;
  }

  .borrego-header__mobile-summary::-webkit-details-marker {
    display: none;
  }

  .borrego-header__mobile-summary svg {
    width: 1.8rem;
    height: 1.8rem;
    flex: 0 0 auto;
    transition: transform 160ms ease;
  }

  .borrego-header__mobile-details[open] .borrego-header__mobile-summary svg {
    transform: rotate(180deg);
  }

  .borrego-header__mobile-sublinks {
    display: grid;
    gap: 1rem;
    padding: 1.4rem 0 1.8rem;
  }

  .borrego-header__mobile-sublink {
    display: inline-flex;
    width: fit-content;
    font-size: 1.45rem;
    letter-spacing: 0.04em;
  }

  .borrego-header__mobile-image {
    display: block;
    overflow: hidden;
    margin: 1rem 0 1.6rem;
    color: #f2ecdd;
    text-decoration: none;
  }

  .borrego-header__mobile-image img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .borrego-header__mobile-image span {
    display: block;
    margin-top: 0.8rem;
    color: #d9b26f;
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .borrego-header__mobile-actions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 3rem;
  }

  .borrego-header__mobile-action {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    min-height: 4.8rem;
    border: 1px solid rgba(242, 236, 221, 0.16);
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .borrego-header__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .borrego-header :focus-visible {
    outline: 0.2rem solid var(--borrego-header-hover);
    outline-offset: 0.3rem;
  }

  @media screen and (max-width: 989px) {
    .borrego-header__announcement {
      min-height: 3.2rem;
      padding-inline: 1.4rem;
      font-size: 0.95rem;
      letter-spacing: 0.12em;
    }

    .borrego-header__bar {
      min-height: 6.4rem;
      padding: 0 1.6rem;
      grid-template-columns: 4rem minmax(0, 1fr) 4rem;
    }

    .borrego-header__desktop-nav,
    .borrego-header__utilities {
      display: none;
    }

    .borrego-header__mobile-toggle {
      display: inline-flex;
      justify-self: start;
    }

    .borrego-header__mobile-close {
      display: inline-flex;
    }

    .borrego-header__mobile-cart {
      display: inline-flex;
      justify-self: end;
    }

    .borrego-header__logo-image {
      width: var(--borrego-logo-mobile-width);
      max-width: 42vw;
    }

    .borrego-header__logo-image--primary.has-mobile-logo,
    .borrego-header.is-transparent:not(.is-scrolled) .borrego-header__logo-image--transparent.has-mobile-logo {
      display: none;
    }

    .borrego-header__logo-image--mobile {
      display: block;
    }
  }

  @media screen and (min-width: 990px) {
    .borrego-header__mobile-cart {
      display: none;
    }
  }
{% endstyle %}

<borrego-header
  class="borrego-header{% if transparent_home %} is-transparent{% endif %}"
  data-transparent-home="{% if transparent_home %}true{% else %}false{% endif %}"
>
  {%- if section.settings.show_announcement and section.settings.announcement_text != blank -%}
    {%- if section.settings.announcement_link != blank -%}
      <a class="borrego-header__announcement" href="{{ section.settings.announcement_link }}">
        {{ section.settings.announcement_text | escape }}
      </a>
    {%- else -%}
      <div class="borrego-header__announcement">
        {{ section.settings.announcement_text | escape }}
      </div>
    {%- endif -%}
  {%- endif -%}

  <div class="borrego-header__shell">
    <div class="borrego-header__bar">
      <button
        type="button"
        class="borrego-header__mobile-toggle"
        aria-label="{{ 'sections.header.menu' | t | default: 'Open menu' }}"
        aria-expanded="false"
        data-borrego-mobile-open
      >
        {{ 'icon-hamburger.svg' | inline_asset_content }}
      </button>

      <nav class="borrego-header__desktop-nav" aria-label="{{ 'sections.header.menu' | t | default: 'Main menu' }}">
        <ul class="borrego-header__nav-list">
          {%- for link in borrego_menu.links -%}
            {%- liquid
              assign link_key = link.title | handleize
              assign has_mega = false
              for block in section.blocks
                if block.type == 'mega_menu' and block.settings.menu_item != blank
                  assign block_key = block.settings.menu_item | handleize
                  if block_key == link_key
                    assign has_mega = true
                  endif
                endif
              endfor
            -%}
            <li class="borrego-header__nav-item" {% if has_mega %}data-borrego-mega-item{% endif %}>
              <a
                class="borrego-header__nav-link"
                href="{{ link.url }}"
                {% if has_mega %}
                  aria-haspopup="true"
                  aria-expanded="false"
                  data-borrego-mega-trigger
                {% endif %}
              >
                {{ link.title | escape }}
              </a>

              {%- if has_mega -%}
                <div class="borrego-header__mega borrego-header__mega--{{ section.settings.mega_menu_theme }}" data-borrego-mega-panel>
                  <div class="borrego-header__mega-inner">
                    <div class="borrego-header__mega-copy">
                      {%- for block in section.blocks -%}
                        {%- liquid
                          assign block_key = block.settings.menu_item | handleize
                        -%}
                        {%- if block.type == 'mega_menu' and block_key == link_key -%}
                          <div class="borrego-header__mega-column" {{ block.shopify_attributes }}>
                            {%- if block.settings.title != blank -%}
                              <p class="borrego-header__mega-title">{{ block.settings.title | escape }}</p>
                            {%- endif -%}
                            {%- if block.settings.links != blank -%}
                              <ul class="borrego-header__mega-links">
                                {%- for mega_link in block.settings.links.links -%}
                                  <li>
                                    <a class="borrego-header__mega-link" href="{{ mega_link.url }}">
                                      {{ mega_link.title | escape }}
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>

                    <div class="borrego-header__mega-media-grid">
                      {%- for block in section.blocks -%}
                        {%- liquid
                          assign block_key = block.settings.menu_item | handleize
                        -%}
                        {%- if block.type == 'mega_menu' and block_key == link_key and block.settings.image != blank -%}
                          <a
                            class="borrego-header__mega-card"
                            href="{% if block.settings.image_link != blank %}{{ block.settings.image_link }}{% else %}{{ link.url }}{% endif %}"
                            {{ block.shopify_attributes }}
                          >
                            {{
                              block.settings.image
                              | image_url: width: 900
                              | image_tag:
                                loading: 'lazy',
                                widths: '360, 540, 720, 900',
                                sizes: '(min-width: 990px) 34vw, 100vw',
                                alt: block.settings.image.alt
                            }}
                            {%- if block.settings.image_caption != blank -%}
                              <span class="borrego-header__mega-caption">{{ block.settings.image_caption | escape }}</span>
                            {%- endif -%}
                          </a>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>

      <a class="borrego-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
        {%- liquid
          assign primary_logo_class = 'borrego-header__logo-image borrego-header__logo-image--primary'
          assign transparent_logo_class = 'borrego-header__logo-image borrego-header__logo-image--transparent'

          if section.settings.logo_transparent != blank
            assign primary_logo_class = primary_logo_class | append: ' has-transparent-logo'
          endif

          if section.settings.logo_mobile != blank
            assign primary_logo_class = primary_logo_class | append: ' has-mobile-logo'
            assign transparent_logo_class = transparent_logo_class | append: ' has-mobile-logo'
          endif
        -%}

        {%- if section.settings.logo_desktop != blank -%}
          {{
            section.settings.logo_desktop
            | image_url: width: 700
            | image_tag:
              class: primary_logo_class,
              widths: '140, 220, 320, 440, 700',
              sizes: '(min-width: 990px) var(--borrego-logo-desktop-width), var(--borrego-logo-mobile-width)',
              preload: true,
              alt: section.settings.logo_desktop.alt
          }}
        {%- elsif section.settings.logo_transparent != blank -%}
          {{
            section.settings.logo_transparent
            | image_url: width: 700
            | image_tag:
              class: primary_logo_class,
              widths: '140, 220, 320, 440, 700',
              sizes: '(min-width: 990px) var(--borrego-logo-desktop-width), var(--borrego-logo-mobile-width)',
              preload: true,
              alt: section.settings.logo_transparent.alt
          }}
        {%- elsif section.settings.logo_transparent == blank and section.settings.logo_mobile == blank -%}
          <span class="borrego-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}

        {%- if section.settings.logo_transparent != blank and section.settings.logo_desktop != blank -%}
          {{
            section.settings.logo_transparent
            | image_url: width: 700
            | image_tag:
              class: transparent_logo_class,
              widths: '140, 220, 320, 440, 700',
              sizes: '(min-width: 990px) var(--borrego-logo-desktop-width), var(--borrego-logo-mobile-width)',
              preload: true,
              alt: section.settings.logo_transparent.alt
          }}
        {%- endif -%}

        {%- if section.settings.logo_mobile != blank -%}
          {{
            section.settings.logo_mobile
            | image_url: width: 420
            | image_tag:
              class: 'borrego-header__logo-image borrego-header__logo-image--mobile',
              widths: '90, 140, 220, 320, 420',
              sizes: 'var(--borrego-logo-mobile-width)',
              preload: true,
              alt: section.settings.logo_mobile.alt
          }}
        {%- endif -%}
      </a>

      <div class="borrego-header__utilities">
        <ul class="borrego-header__utility-list">
          <li>
            <a class="borrego-header__icon" href="{{ routes.search_url }}" aria-label="{{ 'general.search.search' | t }}">
              {{ 'icon-search.svg' | inline_asset_content }}
            </a>
          </li>
          {%- if section.settings.show_account_icon and shop.customer_accounts_enabled -%}
            <li>
              <a
                class="borrego-header__icon"
                href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
                aria-label="{% if customer %}{{ 'customer.account_fallback' | t }}{% else %}{{ 'customer.log_in' | t }}{% endif %}"
                rel="nofollow"
              >
                {{ 'icon-account.svg' | inline_asset_content }}
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.show_wishlist_icon -%}
            <li>
              <a
                class="borrego-header__icon"
                href="{% if section.settings.wishlist_link != blank %}{{ section.settings.wishlist_link }}{% else %}/pages/wishlist{% endif %}"
                aria-label="Wishlist"
              >
                {{ 'icon-heart.svg' | inline_asset_content }}
              </a>
            </li>
          {%- endif -%}
          <li>
            <a class="borrego-header__icon" href="{{ routes.cart_url }}" aria-label="{{ 'templates.cart.cart' | t }}">
              {%- if cart == empty -%}
                {{ 'icon-cart-empty.svg' | inline_asset_content }}
              {%- else -%}
                {{ 'icon-cart.svg' | inline_asset_content }}
                <span class="borrego-header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
                <span class="borrego-header__sr-only">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
              {%- endif -%}
            </a>
          </li>
        </ul>
      </div>

      <a class="borrego-header__icon borrego-header__mobile-cart" href="{{ routes.cart_url }}" aria-label="{{ 'templates.cart.cart' | t }}">
        {%- if cart == empty -%}
          {{ 'icon-cart-empty.svg' | inline_asset_content }}
        {%- else -%}
          {{ 'icon-cart.svg' | inline_asset_content }}
          <span class="borrego-header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
          <span class="borrego-header__sr-only">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>

  <div class="borrego-header__mobile-drawer" data-borrego-mobile-drawer>
    <button class="borrego-header__mobile-overlay" type="button" aria-label="Close menu" data-borrego-mobile-close></button>
    <aside class="borrego-header__mobile-panel" aria-label="{{ 'sections.header.menu' | t | default: 'Mobile menu' }}">
      <div class="borrego-header__mobile-top">
        <span class="borrego-header__mobile-brand">Borrego Streetwear</span>
        <button type="button" class="borrego-header__mobile-close" aria-label="Close menu" data-borrego-mobile-close>
          {{ 'icon-close.svg' | inline_asset_content }}
        </button>
      </div>

      <div class="borrego-header__mobile-content">
        <ul class="borrego-header__mobile-list">
          {%- for link in borrego_menu.links -%}
            {%- liquid
              assign link_key = link.title | handleize
              assign has_mobile_content = false
              if link.links.size > 0
                assign has_mobile_content = true
              endif
              for block in section.blocks
                assign block_key = block.settings.menu_item | handleize
                if block.type == 'mega_menu' and block_key == link_key
                  if block.settings.links != blank or block.settings.image != blank
                    assign has_mobile_content = true
                  endif
                endif
              endfor
            -%}

            <li>
              {%- if has_mobile_content -%}
                <details class="borrego-header__mobile-details">
                  <summary class="borrego-header__mobile-summary">
                    <span>{{ link.title | escape }}</span>
                    {{ 'icon-caret.svg' | inline_asset_content }}
                  </summary>

                  <ul class="borrego-header__mobile-sublinks">
                    <li>
                      <a class="borrego-header__mobile-sublink" href="{{ link.url }}" data-borrego-mobile-link>
                        View all {{ link.title | escape }}
                      </a>
                    </li>
                    {%- for child_link in link.links -%}
                      <li>
                        <a class="borrego-header__mobile-sublink" href="{{ child_link.url }}" data-borrego-mobile-link>
                          {{ child_link.title | escape }}
                        </a>
                      </li>
                    {%- endfor -%}
                    {%- for block in section.blocks -%}
                      {%- liquid
                        assign block_key = block.settings.menu_item | handleize
                      -%}
                      {%- if block.type == 'mega_menu' and block_key == link_key and block.settings.links != blank -%}
                        {%- for mega_link in block.settings.links.links -%}
                          <li>
                            <a class="borrego-header__mobile-sublink" href="{{ mega_link.url }}" data-borrego-mobile-link>
                              {{ mega_link.title | escape }}
                            </a>
                          </li>
                        {%- endfor -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>

                  {%- for block in section.blocks -%}
                    {%- liquid
                      assign block_key = block.settings.menu_item | handleize
                    -%}
                    {%- if block.type == 'mega_menu' and block_key == link_key and block.settings.image != blank -%}
                      <a
                        class="borrego-header__mobile-image"
                        href="{% if block.settings.image_link != blank %}{{ block.settings.image_link }}{% else %}{{ link.url }}{% endif %}"
                        data-borrego-mobile-link
                      >
                        {{
                          block.settings.image
                          | image_url: width: 700
                          | image_tag:
                            loading: 'lazy',
                            widths: '320, 480, 700',
                            sizes: '100vw',
                            alt: block.settings.image.alt
                        }}
                        {%- if block.settings.image_caption != blank -%}
                          <span>{{ block.settings.image_caption | escape }}</span>
                        {%- endif -%}
                      </a>
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                </details>
              {%- else -%}
                <a class="borrego-header__mobile-link" href="{{ link.url }}" data-borrego-mobile-link>
                  {{ link.title | escape }}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>

        <ul class="borrego-header__mobile-actions">
          <li>
            <a class="borrego-header__mobile-action" href="{{ routes.search_url }}" data-borrego-mobile-link>
              {{ 'icon-search.svg' | inline_asset_content }}
              <span>Search</span>
            </a>
          </li>
          {%- if section.settings.show_account_icon and shop.customer_accounts_enabled -%}
            <li>
              <a
                class="borrego-header__mobile-action"
                href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
                rel="nofollow"
                data-borrego-mobile-link
              >
                {{ 'icon-account.svg' | inline_asset_content }}
                <span>Account</span>
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.show_wishlist_icon -%}
            <li>
              <a
                class="borrego-header__mobile-action"
                href="{% if section.settings.wishlist_link != blank %}{{ section.settings.wishlist_link }}{% else %}/pages/wishlist{% endif %}"
                data-borrego-mobile-link
              >
                {{ 'icon-heart.svg' | inline_asset_content }}
                <span>Wishlist</span>
              </a>
            </li>
          {%- endif -%}
        </ul>
      </div>
    </aside>
  </div>
</borrego-header>

<script>
  (() => {
    if (customElements.get('borrego-header')) return;

    class BorregoHeader extends HTMLElement {
      connectedCallback() {
        this.openButton = this.querySelector('[data-borrego-mobile-open]');
        this.closeButtons = this.querySelectorAll('[data-borrego-mobile-close]');
        this.mobileLinks = this.querySelectorAll('[data-borrego-mobile-link]');
        this.megaItems = this.querySelectorAll('[data-borrego-mega-item]');
        this.onScroll = this.handleScroll.bind(this);
        this.onKeydown = this.handleKeydown.bind(this);

        this.openButton?.addEventListener('click', () => this.openMobileMenu());
        this.closeButtons.forEach((button) => button.addEventListener('click', () => this.closeMobileMenu()));
        this.mobileLinks.forEach((link) => link.addEventListener('click', () => this.closeMobileMenu()));
        this.megaItems.forEach((item) => this.bindMegaItem(item));
        window.addEventListener('scroll', this.onScroll, { passive: true });
        document.addEventListener('keydown', this.onKeydown);
        this.handleScroll();
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.onScroll);
        document.removeEventListener('keydown', this.onKeydown);
        document.body.classList.remove('borrego-header-lock');
      }

      bindMegaItem(item) {
        const trigger = item.querySelector('[data-borrego-mega-trigger]');
        const close = () => {
          item.classList.remove('is-active');
          trigger?.setAttribute('aria-expanded', 'false');
        };
        const open = () => {
          this.megaItems.forEach((otherItem) => {
            if (otherItem !== item) {
              otherItem.classList.remove('is-active');
              otherItem.querySelector('[data-borrego-mega-trigger]')?.setAttribute('aria-expanded', 'false');
            }
          });
          item.classList.add('is-active');
          trigger?.setAttribute('aria-expanded', 'true');
        };

        item.addEventListener('mouseenter', open);
        item.addEventListener('mouseleave', close);
        item.addEventListener('focusin', open);
        item.addEventListener('focusout', (event) => {
          if (!item.contains(event.relatedTarget)) close();
        });
      }

      handleScroll() {
        this.classList.toggle('is-scrolled', window.scrollY > 12);
      }

      handleKeydown(event) {
        if (event.key !== 'Escape') return;
        this.closeMobileMenu();
        this.megaItems.forEach((item) => {
          item.classList.remove('is-active');
          item.querySelector('[data-borrego-mega-trigger]')?.setAttribute('aria-expanded', 'false');
        });
      }

      openMobileMenu() {
        this.classList.add('is-mobile-open');
        this.openButton?.setAttribute('aria-expanded', 'true');
        document.body.classList.add('borrego-header-lock');
      }

      closeMobileMenu() {
        this.classList.remove('is-mobile-open');
        this.openButton?.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('borrego-header-lock');
      }
    }

    customElements.define('borrego-header', BorregoHeader);
  })();
</script>

